# ==========================================
# SERVER CONFIGURATION
# ==========================================
# The port your Node.js application will bind to
# Type: Number | Default: 3000
SERVER_PORT=3000

# ==========================================
# JSON WEB TOKEN (JWT)
# ==========================================
# Hashing algorithm used to sign the tokens
# Type: String | Default: HS256
JWT_ALGORITHM=HS256

# Secure random string for signing access tokens (e.g., generated via crypto.randomBytes(32).toString('hex'))
# Type: String | Required
JWT_ACCESS_SECRET=your_production_access_secret_here

# Secure random string for signing refresh tokens 
# Type: String | Required
JWT_REFRESH_SECRET=your_production_refresh_secret_here

# Access token lifespan (keep short for security)
# Type: String (e.g., '15m', '1h') | Default: 15m
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token lifespan (can be longer)
# Type: String (e.g., '7d', '30d') | Default: 7d
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# DATABASE CONFIGURATION (POSTGRES / SEQUELIZE)
# ==========================================
# Database credentials
# Type: String | Required
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE_NAME=your_database_name

# Database connection details
# Type: String | Default: 127.0.0.1
DB_HOST=127.0.0.1
# Type: Number | Default: 5432
DB_PORT=5432
# Type: String | Default: postgres
DB_DIALECT=postgres

# --- Database Connection Pool ---
# Maximum number of connection in pool
# Type: Number | Default: 20
DB_POOL_MAX=20
# Minimum number of connection in pool
# Type: Number | Default: 5
DB_POOL_MIN=5
# Maximum time (ms) that pool will try to get connection before throwing error
# Type: Number | Default: 30000
DB_POOL_ACQUIRE=30000
# Maximum time (ms) that a connection can be idle before being released
# Type: Number | Default: 10000
DB_POOL_IDLE=10000
# Maximum retry attempts for DB operations
# Type: Number | Default: 3
DB_RETRY=3

# --- Database Dialect Options & Sync ---
# Enable SSL for database connections (often required in production DBaaS like AWS RDS)
# Type: Boolean (true/false) | Default: false
DB_SSL=false
# Enable keep-alive to prevent dropped connections
# Type: Boolean (true/false) | Default: false
DB_KEEP_ALIVE=false

# Enable SQL query logging in the console
# Type: Boolean (true/false) | Default: false
DB_LOGGING=false

# Sequelize Sync Strategy (Options: NONE, ALTER, FORCE)
# WARNING: Do not use ALTER or FORCE in production; rely on migrations instead.
# Type: String | Default: NONE
DB_SYNC_TYPE=NONE
